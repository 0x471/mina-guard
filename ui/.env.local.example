# Copy to .env.local and fill in values for your environment.

# Lightnet (default)
NEXT_PUBLIC_MINA_ENDPOINT=http://127.0.0.1:8080/graphql
NEXT_PUBLIC_ARCHIVE_ENDPOINT=http://127.0.0.1:8282
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_MINA_NETWORK=testnet
NEXT_PUBLIC_BLOCK_EXPLORER_URL=http://localhost:5001

# Devnet
# NEXT_PUBLIC_MINA_ENDPOINT=https://api.minascan.io/node/devnet/v1/graphql
# NEXT_PUBLIC_ARCHIVE_ENDPOINT=https://api.minascan.io/archive/devnet/v1/graphql
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Enable e2e test helpers (NEVER set in production)
# NEXT_PUBLIC_E2E_TEST=true

# --- NextAuth (Google OAuth gating) ---
# For local dev, flip this ON to bypass all auth entirely:
# NEXT_PUBLIC_AUTH_DISABLED=true
#
# Otherwise, obtain a Google OAuth 2.0 client (web app) and set:
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=<random 32-byte base64>
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# AUTH_ALLOWED_DOMAINS=o1labs.org
# NEXT_PUBLIC_AUTH_ALLOWED_DOMAINS=o1labs.org
#
# AUTH_JWT_SECRET must match the backend's AUTH_JWT_SECRET — the UI signs
# HS256 bearer tokens with this key that the backend verifies.
# AUTH_JWT_SECRET=<same value as backend>
